{
  "cli": {
    "version": ">= 7.1.2"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_NO_CACHE": "1"
      },
      "cache": {
        "disabled": true
      }
    },
    "production": {
      "env": {
        "EXPO_NO_CACHE": "1"
      },
      "cache": {
        "disabled": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}
